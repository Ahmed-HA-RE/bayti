// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  output          = "../lib/generated/prisma"
  previewFeatures = ["strictUndefinedChecks"]
}

datasource db {
  provider = "postgresql"
}

generator json {
  provider = "prisma-json-types-generator"
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
}

enum Role {
  USER
  ADMIN
}

enum PropertyList {
  RENT
  SALE
}

enum Status {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REJECTED
}

enum AgentStatus {
  ACTIVE
  INACTIVE
}

enum AgentRole {
  SALES
  LEASING
  PROPERTY_MANAGER
  LISTING
  BUYERS_AGENT
  LUXURY_SPECIALIST
  COMMERCIAL
  RENTAL_CONSULTANT
  CONSULTANT
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

// Users
model User {
  id                 String             @id
  name               String
  email              String
  emailVerified      Boolean            @default(false)
  image              String             @default("https://ppnu5kv8ri.ufs.sh/f/C8YtGYjaurIozgAR40BYTPzRI0aonrX1OGyScdC5s6gm27Au")
  imageKey           String?            @unique
  role               Role               @default(USER)
  phoneNumber        String?
  banned             Boolean?           @default(false)
  banReason          String?
  banExpires         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  sessions           Session[]
  accounts           Account[]
  bookings           Booking[]
  favoriteProperties FavoriteProperty[]
  twoFactorEnabled   Boolean?           @default(false)
  twofactors         TwoFactor[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Properties
model Property {
  id                 String             @id @default(uuid())
  name               String
  description        String
  address            String
  longitude          Float
  latitude           Float
  city               String
  price              Int
  area               Int
  bedrooms           Int
  bathrooms          Int
  propertyImages     PropertyImage[]
  isFeatured         Boolean            @default(false)
  propertyList       PropertyList
  propertyType       String
  status             PropertyStatus     @default(AVAILABLE)
  amenities          String[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  bookings           Booking[]
  agent              Agent              @relation(fields: [agentId], references: [id])
  agentId            String
  favoriteProperties FavoriteProperty[]
}

model PropertyImage {
  id         String   @id @default(uuid())
  url        String
  key        String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  @@unique([key])
}

// Bookings
model Booking {
  id              String   @id @default(uuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id])
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  date            DateTime
  startTime       DateTime @db.Time
  endTime         DateTime @db.Time
  userName        String
  userEmail       String
  userPhoneNumber String
  status          Status   @default(PENDING)
  cancelReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Agents 
model Agent {
  id               String      @id @default(uuid())
  name             String
  slug             String      @unique
  description      String
  email            String      @unique
  image            String
  imageKey         String
  phoneNumber      String
  role             AgentRole
  location         String
  city             String
  status           AgentStatus @default(ACTIVE)
  /// [SocialMediaLinks]
  socialMediaLinks Json[]
  properties       Property[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

// Blogs
model Blog {
  id            String     @id @default(uuid())
  title         String
  slug          String     @unique
  tag           String
  content       String?    @db.Text
  status        BlogStatus @default(DRAFT)
  coverImageUrl String
  coverImageKey String
  readTime      Int
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// Favorites
model FavoriteProperty {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, propertyId], name: "favorite_user_property")
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}
